<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tracker_gradient"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <ImageButton
            android:id="@+id/btnBackSharing"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_tracker_card"
            android:contentDescription="@string/app_name"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/tracker_primary_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_home_hero"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sharing_title"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/sharing_subtitle"
                android:textColor="@color/home_hero_subtitle"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_tracker_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/progress_card_title"
                android:textColor="@color/tracker_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/progress_card_body"
                android:textColor="@color/tracker_secondary_text"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareProgress"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/share_progress"
                app:backgroundTint="@color/tracker_accent"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_share" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInviteSms"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/invite_sms"
                android:textColor="@color/tracker_primary_text"
                app:backgroundTint="@color/tracker_chip_bg"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_email"
                app:iconTint="@color/tracker_primary_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyStats"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/copy_stats"
                android:textColor="@color/tracker_primary_text"
                app:backgroundTint="@color/tracker_chip_bg"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="@color/tracker_primary_text" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
